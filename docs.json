{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Grafite Handbook",
  "colors": {
    "primary": "#96adde",
    "light": "#ffffff",
    "dark": "#0f0f10"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Grafite",
          "icon": "globe",
          "href": "https://grafite.app"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Handbook contents",
        "groups": [
          {
            "group": "Grafite Overview",
            "pages": [
              "index",
              "overview"
            ]
          },
          {
            "group": "Touch Screen Basics",
            "pages": [
              "basic-gestures"
            ]
          },
          {
            "group": "Top Left Area",
            "pages": [
              "file-menu",
              "gallery-button"
            ]
          },
          {
            "group": "Top Right Area",
            "pages": [
              "view",
              "import",
              "export",
              "canvas"
            ]
          },
          {
            "group": "Left Toolbar",
            "pages": [
              "brushes"
            ]
          }
        ]
      }
    ]
  },
  "logo": "/images/logo.png",
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@mintlify.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "instagram": "https://www.instagram.com/alexandrebobeda/"
    }
  },
  "appearance": {
    "strict": true
  },
  "fonts": {
    "family": "Geist",
    "weight": 500,
    "heading": {
      "family": "Geist",
      "weight": 700
    }
  },
  "background": {
    "color": {
      "dark": "#0f0f10"
    }
  }
}
