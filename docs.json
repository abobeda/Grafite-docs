{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Grafite Handbook",
  "colors": {
    "primary": "#bebebe",
    "light": "#ffffff",
    "dark": "#0f0f10"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Grafite",
          "icon": "globe",
          "href": "https://grafite.app"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Handbook contents",
        "groups": [
          {
            "group": "Grafite Overview",
            "pages": ["index", "overview"]
          },
          {
            "group": "Home screen",
            "pages": [
              "all-boards",
              "recently-added",
              "organize-boards",
              "add-board",
              "info-and-help"
            ]
          },
          {
            "group": "Board screen",
            "pages": [
              "inside-a-board",
              "organize-references"
            ]
          },
          {
            "group": "References screen",
            "pages": []
          }
        ]
      }
    ]
  },
  "logo": "/images/logo.png",
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@grafite.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Download Grafite",
      "href": "https://grafite.app"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "instagram": "https://www.instagram.com/alexandrebobeda/"
    }
  },
  "appearance": {
    "strict": true
  },
  "fonts": {
    "family": "Geist",
    "weight": 500,
    "heading": {
      "family": "Geist",
      "weight": 700
    }
  },
  "background": {
    "color": {
      "dark": "#0f0f10"
    }
  }
}
